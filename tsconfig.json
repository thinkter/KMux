{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "sourceMap": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "resolveJsonModule": true
    ,
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "forge.env.d.ts",
    "forge.config.ts",
    "vite.*.config.ts",
    "src/**/*"
  ]
}
